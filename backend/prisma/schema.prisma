// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  PRACTITIONER
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  name         String
  role         Role   @default(PATIENT)
  status               String    @default("ACTIVE") // ACTIVE or SUSPENDED
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  practitionerProfile PractitionerProfile?

  appointmentsAsPatient Appointment[]  @relation("PatientAppointments")
  orders                Order[]
  prescriptions         Prescription[] @relation("PatientPrescriptions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PractitionerProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  specialties     String[]
  bio             String?
  consultationFee Float    @default(0)
  kycVerified     Boolean  @default(false)
  kycPhoto        String?  // Base64 encoded selfie captured during KYC

  appointments  Appointment[]  @relation("PractitionerAppointments")
  prescriptions Prescription[] @relation("PractitionerPrescriptions")
}

model Appointment {
  id        String @id @default(uuid())
  patientId String
  patient   User   @relation("PatientAppointments", fields: [patientId], references: [id])

  practitionerId String
  practitioner   PractitionerProfile @relation("PractitionerAppointments", fields: [practitionerId], references: [id])

  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(SCHEDULED)
  notes     String?
  meetLink  String?

  prescriptions Prescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prescription {
  id            String       @id @default(uuid())
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  patientId String
  patient   User   @relation("PatientPrescriptions", fields: [patientId], references: [id])

  practitionerId String
  practitioner   PractitionerProfile @relation("PractitionerPrescriptions", fields: [practitionerId], references: [id])

  medicines PrescriptionMedicine[]
  lifestyle String?
  status    String                 @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrescriptionMedicine {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  name      String
  dosage    String
  frequency String
  timing    String
  duration  String
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  totalAmount Float
  status      String   @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  level     String   @default("INFO") // INFO, WARNING, ERROR, CRITICAL
  createdAt DateTime @default(now())
}
